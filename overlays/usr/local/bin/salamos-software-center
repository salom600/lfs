#!/bin/bash
# SalamOS Software Center - 2026 Modern Edition
# One-click app installation like Windows
# ============================================
export PATH=/usr/sbin:/usr/bin:/sbin:/bin

declare -A APPS=(
  ["Firefox Browser"]="firefox-esr"
  ["Chromium Browser"]="chromium"
  ["Thunderbird Email"]="thunderbird"
  ["Transmission Torrent"]="transmission-gtk"
  ["LibreOffice Full"]="libreoffice"
  ["LibreOffice Writer"]="libreoffice-writer"
  ["LibreOffice Calc"]="libreoffice-calc"
  ["VLC Media Player"]="vlc"
  ["mpv Player (Light)"]="mpv"
  ["GIMP Image Editor"]="gimp"
  ["Inkscape Vector"]="inkscape"
  ["VS Code"]="code"
  ["Geany IDE"]="geany"
  ["Telegram"]="telegram-desktop"
  ["Discord"]="discord"
  ["BleachBit (Cleaner)"]="bleachbit"
  ["Timeshift (Backup)"]="timeshift"
  ["Steam (Games)"]="steam"
  ["Lutris (Games)"]="lutris"
  ["Wine (Windows apps)"]="wine"
)

case "${1:-}" in
  install)
    echo "Installing $2..."
    sudo apt-get install -y "$2" ;;
  remove)
    echo "Removing $2..."
    sudo apt-get remove --purge -y "$2"
    sudo apt-get autoremove -y --purge ;;
  search)
    apt-cache search "$2" | head -20 ;;
  list)
    echo "=== SalamOS Software Center ==="
    for app in "${!APPS[@]}"; do
      printf "%-30s %s\n" "$app" "${APPS[$app]}"
    done | sort ;;
  gui)
    if command -v rofi &>/dev/null; then
      choice=$(for app in "${!APPS[@]}"; do echo "$app"; done | sort | \
        rofi -dmenu -p "SalamOS Software Center" -i -config ~/.config/rofi/config.rasi)
      if [ -n "$choice" ]; then
        pkg="${APPS[$choice]}"
        if [ -n "$pkg" ]; then
          lxterminal -e bash -c "sudo apt-get install -y $pkg; echo 'Done! Press Enter to close.'; read"
        fi
      fi
    else
      echo "=== SalamOS Software Center ==="
      for app in "${!APPS[@]}"; do printf "%-30s %s\n" "$app" "${APPS[$app]}"; done | sort
      read -p "Enter package to install: " pkg
      sudo apt-get install -y "$pkg"
    fi ;;
  *)
    echo "SalamOS Software Center"
    echo "Commands: install|remove|search|list|gui <package>" ;;
esac
