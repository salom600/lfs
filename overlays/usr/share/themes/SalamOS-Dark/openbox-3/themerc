# SalamOS-Dark Openbox Theme
# Professional dark theme matching GTK theme
# ============================================

# Window geometry
border.width: 1
padding.width: 4
padding.height: 4
window.handle.width: 2

# Colors
window.active.border.color: #e94560
window.inactive.border.color: #0f3460
window.active.client.color: #e94560
window.inactive.client.color: #0f3460
window.active.handle.color: #0f3460
window.inactive.handle.color: #16213e

# Title bar
window.active.title.bg: flat solid
window.active.title.bg.color: #0f3460
window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #16213e

# Title text
window.active.label.text.color: #ffffff
window.inactive.label.text.color: #808090
window.label.text.justify: left

# Buttons
window.active.button.unpressed.bg: flat solid
window.active.button.unpressed.bg.color: #0f3460
window.active.button.unpressed.image.color: #ffffff

window.active.button.pressed.bg: flat solid
window.active.button.pressed.bg.color: #e94560
window.active.button.pressed.image.color: #ffffff

window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: #1a1a2e
window.active.button.hover.image.color: #e94560

window.inactive.button.unpressed.bg: flat solid
window.inactive.button.unpressed.bg.color: #16213e
window.inactive.button.unpressed.image.color: #808090

window.inactive.button.pressed.bg: flat solid
window.inactive.button.pressed.bg.color: #1a1a2e
window.inactive.button.pressed.image.color: #808090

window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: #0f3460
window.inactive.button.hover.image.color: #e0e0e0

# Menu
menu.overlap: 0
menu.title.bg: flat solid
menu.title.bg.color: #0f3460
menu.title.text.color: #ffffff
menu.items.bg: flat solid
menu.items.bg.color: #1a1a2e
menu.items.text.color: #e0e0e0
menu.items.active.bg: flat solid
menu.items.active.bg.color: #0f3460
menu.items.active.text.color: #ffffff
menu.items.disabled.text.color: #808090
menu.separator.color: #0f3460
menu.border.color: #0f3460
menu.border.width: 1

# OSD
osd.bg: flat solid
osd.bg.color: #1a1a2e
osd.label.text.color: #e0e0e0
osd.hilight.bg: flat solid
osd.hilight.bg.color: #e94560
osd.unhilight.bg: flat solid
osd.unhilight.bg.color: #16213e
osd.border.color: #0f3460
osd.border.width: 1
