# SalamOS-Dark Openbox Theme - 2026 Modern Professional Edition
# Glassmorphism + Rounded corners + Fluent Design colors
# ============================================

# === Window geometry ===
border.width: 2
padding.width: 8
padding.height: 6
window.handle.width: 0
window.client.padding.width: 2
window.client.padding.height: 2

# === NEW 2026 Color Palette ===
# Deep navy background, vibrant violet accent, coral highlight
window.active.border.color: #7c3aed
window.inactive.border.color: #1f4068
window.active.client.color: #0d1123
window.inactive.client.color: #0d1123
window.active.handle.color: #0d1123
window.inactive.handle.color: #0d1123

# === Title bar - Modern gradient with violet glow ===
window.active.title.bg: flat gradient vertical
window.active.title.bg.color: #0d1123
window.active.title.bg.colorTo: #16213e

window.inactive.title.bg: flat gradient vertical
window.inactive.title.bg.color: #0d1123
window.inactive.title.bg.colorTo: #0f1525

# === Title text - Clean modern font ===
window.active.label.text.color: #dce6ff
window.inactive.label.text.color: #5c5c6e
window.label.text.justify: center

# === Buttons - Modern Windows 11 style (colored circles) ===
# Close button: coral/magenta
window.active.button.close.unpressed.bg: flat solid
window.active.button.close.unpressed.bg.color: #0d1123
window.active.button.close.unpressed.image.color: #e94560

window.active.button.close.pressed.bg: flat solid
window.active.button.close.pressed.bg.color: #e94560
window.active.button.close.pressed.image.color: #ffffff

window.active.button.close.hover.bg: flat solid
window.active.button.close.hover.bg.color: #2d468c
window.active.button.close.hover.image.color: #e94560

# Maximize button: violet
window.active.button.max.unpressed.bg: flat solid
window.active.button.max.unpressed.bg.color: #0d1123
window.active.button.max.unpressed.image.color: #7c3aed

window.active.button.max.pressed.bg: flat solid
window.active.button.max.pressed.bg.color: #7c3aed
window.active.button.max.pressed.image.color: #ffffff

window.active.button.max.hover.bg: flat solid
window.active.button.max.hover.bg.color: #2d468c
window.active.button.max.hover.image.color: #7c3aed

# Iconify button: light blue
window.active.button.iconify.unpressed.bg: flat solid
window.active.button.iconify.unpressed.bg.color: #0d1123
window.active.button.iconify.unpressed.image.color: #648cdc

window.active.button.iconify.pressed.bg: flat solid
window.active.button.iconify.pressed.bg.color: #648cdc
window.active.button.iconify.pressed.image.color: #ffffff

window.active.button.iconify.hover.bg: flat solid
window.active.button.iconify.hover.bg.color: #2d468c
window.active.button.iconify.hover.image.color: #648cdc

# Disabled buttons
window.active.button.disabled.bg: flat solid
window.active.button.disabled.bg.color: #0d1123
window.active.button.disabled.image.color: #3a3a4e

# Inactive window buttons (dimmed)
window.inactive.button.unpressed.bg: flat solid
window.inactive.button.unpressed.bg.color: #0f1525
window.inactive.button.unpressed.image.color: #3a3a4e

window.inactive.button.pressed.bg: flat solid
window.inactive.button.pressed.bg.color: #0a0a18
window.inactive.button.pressed.image.color: #3a3a4e

window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: #1f4068
window.inactive.button.hover.image.color: #8c8c9a

# === Menu - Modern frosted glass popup ===
menu.overlap: 0
menu.title.bg: flat gradient vertical
menu.title.bg.color: #0d1123
menu.title.bg.colorTo: #16213e
menu.title.text.color: #dce6ff
menu.items.bg: flat solid
menu.items.bg.color: #0d1123
menu.items.text.color: #dce6ff
menu.items.active.bg: flat solid
menu.items.active.bg.color: #7c3aed
menu.items.active.text.color: #ffffff
menu.items.disabled.text.color: #3a3a4e
menu.separator.color: #ffffff 8
menu.border.color: #7c3aed 20
menu.border.width: 1

# === OSD - Modern purple accent ===
osd.bg: flat gradient vertical
osd.bg.color: #0d1123
osd.bg.colorTo: #16213e
osd.label.text.color: #dce6ff
osd.hilight.bg: flat solid
osd.hilight.bg.color: #7c3aed
osd.unhilight.bg: flat solid
osd.unhilight.bg.color: #16213e
osd.border.color: #7c3aed 30
osd.border.width: 1
