# SalamOS-Dark Openbox Theme - 2026 PROFESSIONAL Edition
# Fluent Design: Clean borders, subtle gradients, proper window buttons
# ============================================

# === Window geometry - Modern slim borders ===
border.width: 1
padding.width: 6
padding.height: 4
window.handle.width: 0
window.client.padding.width: 1
window.client.padding.height: 1

# === Color Palette - Professional dark with violet accent ===
window.active.border.color: #7c3aed
window.inactive.border.color: #1f4068

window.active.client.color: #0d1123
window.inactive.client.color: #0d1123

window.active.handle.color: #0d1123
window.inactive.handle.color: #0d1123

# === Title bar - Modern Fluent Design slim header ===
window.active.title.bg: flat solid
window.active.title.bg.color: #0d1123

window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #0d1123

# === Title text - Centered, modern font ===
window.active.label.text.color: #ffffff
window.inactive.label.text.color: #5c5c6e
window.label.text.justify: left

# === Window Buttons - PROPER Fluent Design style ===
# NOT colored dots - proper window management symbols

# Close button: Red/coral when hovered (Windows 11 red accent)
window.active.button.close.unpressed.bg: parentrelative
window.active.button.close.unpressed.image.color: #8c8c9a

window.active.button.close.pressed.bg: flat solid
window.active.button.close.pressed.bg.color: #e94560
window.active.button.close.pressed.image.color: #ffffff

window.active.button.close.hover.bg: flat solid
window.active.button.close.hover.bg.color: #e94560
window.active.button.close.hover.image.color: #ffffff

# Maximize button: Violet accent on hover
window.active.button.max.unpressed.bg: parentrelative
window.active.button.max.unpressed.image.color: #8c8c9a

window.active.button.max.pressed.bg: flat solid
window.active.button.max.pressed.bg.color: #7c3aed
window.active.button.max.pressed.image.color: #ffffff

window.active.button.max.hover.bg: flat solid
window.active.button.max.hover.bg.color: #2d468c
window.active.button.max.hover.image.color: #dce6ff

# Iconify/minimize button: Subtle on hover
window.active.button.iconify.unpressed.bg: parentrelative
window.active.button.iconify.unpressed.image.color: #8c8c9a

window.active.button.iconify.pressed.bg: flat solid
window.active.button.iconify.pressed.bg.color: #2d468c
window.active.button.iconify.pressed.image.color: #ffffff

window.active.button.iconify.hover.bg: flat solid
window.active.button.iconify.hover.bg.color: #2d468c
window.active.button.iconify.hover.image.color: #dce6ff

# Disabled buttons
window.active.button.disabled.bg: parentrelative
window.active.button.disabled.image.color: #3a3a4e

# Inactive window buttons (dimmed gray, no color accents)
window.inactive.button.unpressed.bg: parentrelative
window.inactive.button.unpressed.image.color: #3a3a4e

window.inactive.button.pressed.bg: parentrelative
window.inactive.button.pressed.image.color: #3a3a4e

window.inactive.button.hover.bg: parentrelative
window.inactive.button.hover.image.color: #5c5c6e

# === Menu - Modern frosted glass popup ===
menu.overlap: 0
menu.title.bg: flat solid
menu.title.bg.color: #16213e
menu.title.text.color: #dce6ff

menu.items.bg: flat solid
menu.items.bg.color: #0d1123
menu.items.text.color: #dce6ff

menu.items.active.bg: flat solid
menu.items.active.bg.color: #7c3aed
menu.items.active.text.color: #ffffff

menu.items.disabled.text.color: #3a3a4e
menu.separator.color: #ffffff 8
menu.border.color: #7c3aed 30
menu.border.width: 1

# === OSD - Modern violet accent ===
osd.bg: flat solid
osd.bg.color: #0d1123
osd.label.text.color: #dce6ff
osd.hilight.bg: flat solid
osd.hilight.bg.color: #7c3aed
osd.unhilight.bg: flat solid
osd.unhilight.bg.color: #16213e
osd.border.color: #7c3aed 40
osd.border.width: 1
