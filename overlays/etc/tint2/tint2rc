# SalamOS tint2 Panel - Modern Taskbar Design
# Windows 11 inspired with SalamOS identity
# ============================================

# Backgrounds - Modern glass effect
# Background 1: Panel background (dark glass)
rounded = 8
border_width = 0
background_color = #1b1b2f 90
border_color = #1f4068 80

# Background 2: Task/app background
rounded = 6
border_width = 0
background_color = #162447 80
border_color = #1f4068 80

# Background 3: Active task (highlighted)
rounded = 6
border_width = 0
background_color = #1f4068 95
border_color = #e43f5a 100

# Background 4: Hover task
rounded = 6
border_width = 0
background_color = #1f4068 50
border_color = #e43f5a 50

# Background 5: Launcher background
rounded = 6
border_width = 0
background_color = #162447 60
border_color = #1f4068 60

# Panel - Center bottom, modern sizing
panel_items = LSCB
panel_position = bottom center horizontal
panel_size = 98% 38
panel_margin = 4 2
panel_padding = 6 0 6
panel_background_id = 1
panel_shrink = 0
panel_dock = 0
panel_layer = top
strut_policy = follow_size

# Launcher - Modern app icons on left
launcher_padding = 4 2 4
launcher_background_id = 5
launcher_icon_theme = Papirus
launcher_icon_size = 22
launcher_item_app = /usr/share/applications/firefox-esr.desktop
launcher_item_app = /usr/share/applications/pcmanfm.desktop
launcher_item_app = /usr/share/applications/lxterminal.desktop
launcher_tooltip = 1

# Taskbar - Modern task buttons
taskbar_padding = 2 2 4
taskbar_background_id = 2
taskbar_active_background_id = 3
taskbar_name = 1
taskbar_name_padding = 8 2
taskbar_name_font = sans 9
taskbar_name_active_font_color = #ffffff 100
taskbar_name_font_color = #8c8c9a 100
taskbar_name_urgent_font_color = #ffffff 100

# Systray - Right side system icons
systray_padding = 6 0 6
systray_background_id = 2
systray_sort = right
systray_icon_size = 18
systray_icon_ascent = 6

# Clock - Modern time display
time1_format = %H:%M
time1_font = sans bold 10
time2_format = %a %d
time2_font = sans 8
clock_font_color = #e8e8e8 100
clock_padding = 10 4
clock_background_id = 2
clock_lclick_command = lxterminal -e calcurse
clock_rclick_command = none

# Battery
battery_padding = 6 0 6
battery_background_id = 2
battery_center = true
battery_font = sans 9
battery_font_color = #e8e8e8 100

# Separator
separator_padding = 1 0 2
separator_background_id = 0
separator_color = rgba(255,255,255,0.06) 100

# Mouse actions
mouse_middle = none
mouse_right = close
mouse_scroll_up = toggle
mouse_scroll_down = iconify

# Tooltips
tooltip_padding = 6 6
tooltip_background_id = 2
tooltip_font_color = #e8e8e8 100
tooltip_font = sans 9
tooltip_show_timeout = 0.3
tooltip_hide_timeout = 0.3
